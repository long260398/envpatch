{
  "name": "envpatch",
  "version": "0.1.2",
  "description": "CLI tool to validate, diff, and sync .env files against .env.example",
  "bin": {
    "envpatch": "bin/envx.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "env",
    "dotenv",
    "cli",
    "developer-tools",
    "environment",
    "validation",
    "devops"
  ],
  "author": "long260398",
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
